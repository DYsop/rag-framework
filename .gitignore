# ============================================================
# .gitignore – Agentengestütztes RAG-Framework
# ============================================================

# --- Umgebungsvariablen / Secrets ---
.env
.env.*
!.env.example
*.key
*.pem

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# --- Jupyter ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# --- Lokale Rohdaten (NICHT versionieren) ---
data/raw/
data/processed/
data/interim/
data/external/
!data/sample/
!data/gold_standard/
!data/README.md
!data/.gitkeep

# --- Große Dokumente / Binärdateien ---
*.pdf
*.docx
*.pptx
*.xlsx
*.zip
*.tar
*.tar.gz
!assets/**/*.png
!docs/**/*.png

# --- Vektorindizes / lokale Datenbanken ---
*.faiss
*.index
*.bin
qdrant_storage/
chroma/
.chroma/
*.sqlite
*.sqlite3
*.db
neo4j/

# --- Logs / temporäre Dateien ---
logs/
*.log
tmp/
.tmp/
*.tmp
.cache/

# --- Node / Frontend ---
node_modules/
.next/
.vercel/
dist-ssr/
*.local

# --- IDE / OS ---
.DS_Store
Thumbs.db
.idea/
*.swp
