# ============================================================
# .gitignore – Agentengestuetztes RAG-Framework
# ============================================================

# --- Umgebungsvariablen / Secrets ---
.env
.env.*
!.env.example
*.key
*.pem

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# --- Jupyter ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# --- Lokale Roh- und Prozessdaten (NICHT versionieren) ---
data/raw/
data/processed/
data/interim/
data/external/
data/cache/
data/vectorstores/
data/indexes/

# --- Kleine, kuratierte Daten behalten ---
!data/sample/
!data/samples/
!data/samples/**
!data/gold_standard/
!data/README.md
!data/.gitkeep

# --- Grosse Dokumente / Binaerdateien ---
*.pdf
*.parquet
*.docx
*.pptx
*.xlsx
*.zip
*.tar
*.tar.gz

# Generierte Excel/CSV/JSON-Exporte der Pipeline (lokal halten)
data/processed/*.xlsx
data/processed/*.csv
data/processed/*.json

# --- Dokumentierte, ausgewaehlte Ergebnisartefakte BEHALTEN ---
# Wichtig: docs/results/ bleibt versionierbar, obwohl data/processed/ ignoriert wird.
!docs/results/
!docs/results/**
!docs/results/**/*.json
!docs/results/**/*.csv
!docs/results/**/*.png
!docs/results/**/*.md

# Abbildungen in assets/docs weiterhin erlauben
!assets/**/*.png
!docs/**/*.png

# --- Vektorindizes / lokale Datenbanken ---
*.faiss
*.index
*.bin
qdrant_storage/
chroma/
.chroma/
*.sqlite
*.sqlite3
*.db
neo4j/

# --- Logs / temporaere Dateien ---
logs/
*.log
tmp/
.tmp/
*.tmp
.cache/

# --- Node / Frontend ---
node_modules/
.next/
.vercel/
dist-ssr/
*.local

# --- IDE / OS ---
.DS_Store
Thumbs.db
.idea/
*.swp
